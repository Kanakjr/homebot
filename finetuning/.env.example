# HuggingFace & Gemini (Finetuning/Distillation Specific)
GEMINI_API_KEY=your_gemini_api_key_here
HF_TOKEN=your_hugging_face_token_here

# Base Teacher Model for DeepAgent
MODEL=google_genai:gemini-2.5-flash

# Home Assistant
HA_URL=http://192.168.68.100:8123
HA_TOKEN=your_ha_long_lived_token

# Media Services
SONARR_URL=http://192.168.68.100:8989
SONARR_API_KEY=your_sonarr_key
RADARR_URL=http://192.168.68.100:7878
RADARR_API_KEY=your_radarr_key
TRANSMISSION_URL=http://192.168.68.100:9091
JELLYSEERR_URL=http://192.168.68.100:5055
JELLYSEERR_API_KEY=your_jellyseerr_key
PROWLARR_URL=http://192.168.68.100:9696
PROWLARR_API_KEY=your_prowlarr_key
JELLYFIN_URL=http://192.168.68.100:8096
JELLYFIN_API_KEY=your_jellyfin_key

# LangSmith tracing (Crucial for extracting the simulation traces)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=homebot-deepagent
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=homebot-deepagent
