# HomeBotAI - Backend Configuration
# Copy to .env and fill in your actual values.

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Comma-separated Telegram user IDs (leave empty to allow all)
TELEGRAM_ALLOWED_USERS=

# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Home Assistant
HA_URL=http://your-server-ip:8123
HA_TOKEN=your-ha-long-lived-access-token

# n8n
N8N_URL=http://your-server-ip:5678
N8N_API_KEY=

# Sonarr
SONARR_URL=http://your-server-ip:8989
SONARR_API_KEY=your-sonarr-api-key

# Transmission
TRANSMISSION_URL=http://your-server-ip:9091

# Jellyseerr
JELLYSEERR_URL=http://your-server-ip:5055
JELLYSEERR_API_KEY=your-jellyseerr-api-key

# Prowlarr
PROWLARR_URL=http://your-server-ip:9696
PROWLARR_API_KEY=your-prowlarr-api-key

# Jellyfin
JELLYFIN_URL=http://your-server-ip:8096
JELLYFIN_API_KEY=your-jellyfin-api-key

# LangSmith tracing (https://smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=kanohomebot

# CORS origins for dashboard (comma-separated)
CORS_ORIGINS=http://localhost:3001

# Database path
DB_PATH=/tmp/homebot_dev/homebot.db
TZ=Asia/Kolkata
