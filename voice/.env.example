# --- Gemini Live (required) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Live model + voice. Defaults are fine for most people.
# Voices: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr
#
# Model choices (April 2026):
#   gemini-3.1-flash-live-preview                    <- half-cascade, best tool calling (default)
#   gemini-2.5-flash-native-audio-latest             <- nicer voice, weaker tool calling
#   gemini-2.5-flash-native-audio-preview-12-2025    <- pinned Dec 2025 native audio
LIVE_MODEL=gemini-3.1-flash-live-preview
LIVE_VOICE=Charon

# Close a session after this many seconds of no message from Gemini
# (model finished speaking and you're not talking either). Keep a wake
# word to start the next one.
SESSION_IDLE_TIMEOUT_S=10
# Hard ceiling (Gemini Live caps audio-only sessions at ~15 min; stay below).
SESSION_MAX_S=780

# --- Wake word ---
WAKE_WORD=hey_jarvis_v0.1
WAKE_THRESHOLD=0.5

# --- Audio devices (optional) ---
# Run `python -c "import sounddevice as sd; print(sd.query_devices())"`
# to list input/output devices, then set the index of your far-field array
# (e.g. ReSpeaker XVF3800) and your preferred output.
# MIC_DEVICE_INDEX=2
# SPEAKER_DEVICE_INDEX=1

# --- Home Assistant (direct fast path) ---
HA_URL=http://your-server-ip:8123
HA_TOKEN=your-ha-long-lived-access-token

# --- Deep Agent (delegate path for complex requests) ---
DEEPAGENT_URL=http://localhost:8322
DEEPAGENT_API_KEY=
VOICE_THREAD_ID=voice

# --- Media services (optional; enables media_now_playing + media_downloads_status) ---
JELLYFIN_URL=
JELLYFIN_API_KEY=
TRANSMISSION_URL=
TRANSMISSION_USERNAME=
TRANSMISSION_PASSWORD=

# --- Logging ---
VOICE_LOG_LEVEL=INFO
